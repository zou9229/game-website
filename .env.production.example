# Inlined into the client JS bundle at `vinext build` time.
# Values here SHIP TO BROWSERS as plain JavaScript — only public values.
# Secrets go via `wrangler secret put`.
# Server-only runtime config goes in wrangler.jsonc `vars`.
#
# Copy this to `.env.production` and edit, OR let /deploy-cloudflare auto-fill
# from your first deploy's Worker URL.

NEXT_PUBLIC_APP_URL=https://shipany-next.your-subdomain.workers.dev
NEXT_PUBLIC_APP_NAME=ShipAny Next
