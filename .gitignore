# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# next.js
/.next/
/out/

# production
/build

# deploy
.vercel

# editors
.idea
.vscode
.cursor

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env — local files hold secrets, never commit (keep .env.example tracked)
.env
.env.*
!.env.example

# typescript
*.tsbuildinfo
next-env.d.ts

# database
/data/
/drizzle/
src/config/db/schema.ts

# npm (project uses pnpm)
package-lock.json

# vinext / vite build output
/dist/
/.vinext/
/.wrangler/
/worker/

# Cloudflare per-project config — generated by /deploy-cloudflare from
# wrangler.example.jsonc and .env.production.example respectively.
# Carries account-specific IDs / URLs that should not be in the template git.
wrangler.jsonc
.env.production

# skills installed via `npx skills add` — keep project-owned skills tracked
/.agents/
/.claude/skills/migrate-to-vinext
skills-lock.json

# user-uploaded files from local dev (ticket attachments etc.)
public/uploads/
