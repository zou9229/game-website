# ShipAny Next — environment variables
#
# Local development:
#   cp .env.example .env.development   # then fill in the values below
#
# Loader priority (scripts/with-env.ts + next dev):
#   .env.{NODE_ENV}.local > .env.{NODE_ENV} > .env.local > .env
# So in dev, .env.development is picked up by both `next dev` and the db scripts.
#
# Only the four "Required" vars are needed to boot a SQLite + localhost setup.
# Everything else is optional — enable a section when you wire that feature.

# ---------------------------------------------------------------------------
# Required
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=My App
DATABASE_PROVIDER=sqlite
DATABASE_URL=file:data/local.db
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# ---------------------------------------------------------------------------
# App (optional — sensible defaults exist in src/config/index.ts)
# ---------------------------------------------------------------------------
NEXT_PUBLIC_APP_DESCRIPTION=Ship your SaaS faster
NEXT_PUBLIC_APP_LOGO=/logo.png
NEXT_PUBLIC_DEFAULT_LOCALE=en

# ---------------------------------------------------------------------------
# Database (advanced / non-sqlite)
# ---------------------------------------------------------------------------
# DATABASE_PROVIDER options: sqlite | postgres | mysql | turso | d1
#   PostgreSQL: postgresql://user:pass@localhost:5432/dbname
#   MySQL:      mysql://user:pass@localhost:3306/dbname
# DATABASE_AUTH_TOKEN=                # Turso auth token
# DB_SCHEMA=public                    # Postgres schema
# DB_SINGLETON_ENABLED=false          # reuse a single connection (serverless)
# DB_MAX_CONNECTIONS=1

# ---------------------------------------------------------------------------
# Auth (optional — AUTH_URL defaults to NEXT_PUBLIC_APP_URL)
# ---------------------------------------------------------------------------
# AUTH_URL=http://localhost:3000
# OAuth providers (Google/GitHub) + Google One Tap are configured in the
# admin panel Settings, not here.

# ---------------------------------------------------------------------------
# Payment — Stripe
# ---------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_SIGNING_SECRET=

# ---------------------------------------------------------------------------
# Payment — PayPal
# ---------------------------------------------------------------------------
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=
PAYPAL_ENVIRONMENT=production

# ---------------------------------------------------------------------------
# Payment — Alipay
# ---------------------------------------------------------------------------
ALIPAY_APP_ID=
ALIPAY_PRIVATE_KEY=
ALIPAY_PUBLIC_KEY=
ALIPAY_NOTIFY_URL=

# ---------------------------------------------------------------------------
# Payment — WeChat Pay
# ---------------------------------------------------------------------------
WECHAT_APP_ID=
WECHAT_MCH_ID=
WECHAT_API_V3_KEY=
WECHAT_PRIVATE_KEY=
WECHAT_SERIAL_NO=
WECHAT_NOTIFY_URL=
WECHAT_PLATFORM_CERT=

# ---------------------------------------------------------------------------
# Email — Resend
# ---------------------------------------------------------------------------
RESEND_API_KEY=
RESEND_EMAIL_FROM=

# ---------------------------------------------------------------------------
# Storage — S3 / R2 (optional; image upload falls back to inline base64)
# ---------------------------------------------------------------------------
STORAGE_ENDPOINT=
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=
STORAGE_PUBLIC_DOMAIN=
INLINE_IMAGE_MAX_KB=2048

# ---------------------------------------------------------------------------
# AI — Replicate
# ---------------------------------------------------------------------------
REPLICATE_API_TOKEN=
